#!/usr/bin/env bash
# kanban — KanBanLess CLI
# Manages a Kanban board entirely in the file system.
# Board = directory, Columns = subdirectories, Tasks = .md files

set -euo pipefail

COLUMNS=("backlog" "todo" "doing" "done")

usage() {
  cat <<EOF
Usage: kanban <command> [args]

Commands:
  init [name]             Create a board folder with 4 column directories.
                          Defaults to 'kanban'; auto-increments if it exists
                          (kanban-1, kanban-2, …). cd into the folder to use
                          other commands.
  add <title>             Create a new task .md in backlog/
  move <task> <column>    Move a task file to a new column directory
  list [column]           List tasks; ordered by order.txt, then priority
    [--priority high|medium|low]  Filter by priority
    [--tag <tag>]                 Filter by tag
  show <task>             Display a task's content
  check <task> <item>     Mark a checklist item complete
  status                  Show board summary (count per column)
  order <task> top        Move task to top of its column
  order <task> bottom     Move task to bottom of its column
  order <task> up [N]     Move task up N positions (default 1)
  order <task> down [N]   Move task down N positions (default 1)

Columns: backlog, todo, doing, done
EOF
}

# Convert a title to a URL/filename-safe slug
slugify() {
  echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9]/-/g' \
    | sed 's/-\+/-/g' \
    | sed 's/^-//;s/-$//'
}

# Find which column contains a given task slug; prints the path or exits 1
find_task() {
  local slug="$1"
  # Validate slug to prevent path traversal and enforce slug format
  if [[ ! "$slug" =~ ^[a-z0-9-]+$ ]]; then
    echo "Error: invalid task slug '$slug'. Slugs must contain only lowercase letters, digits, and dashes." >&2
    return 1
  fi
  for col in "${COLUMNS[@]}"; do
    if [[ -f "$col/${slug}.md" ]]; then
      echo "$col/${slug}.md"
      return 0
    fi
  done
  echo "Error: task not found: $slug" >&2
  return 1
}

# Remove a slug from a column's order.txt (no-op if file absent)
order_remove() {
  local col="$1" slug="$2"
  local f="$col/order.txt"
  [[ -f "$f" ]] || return 0
  local lines=()
  while IFS= read -r line; do
    local trimmed
    trimmed="$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    [[ "$trimmed" == "$slug" ]] || lines+=("$line")
  done < "$f"
  if [[ ${#lines[@]} -gt 0 ]]; then
    printf '%s\n' "${lines[@]}" > "$f"
  else
    : > "$f"
  fi
}

# Append a slug to a column's order.txt
order_append() {
  local col="$1" slug="$2"
  printf '%s\n' "$slug" >> "$col/order.txt"
}

# Validate that a column name is one of the four known columns
validate_column() {
  local col="$1"
  for c in "${COLUMNS[@]}"; do
    [[ "$c" == "$col" ]] && return 0
  done
  echo "Error: invalid column '$col'. Must be one of: ${COLUMNS[*]}" >&2
  return 1
}

cmd="${1:-}"
shift || true

case "$cmd" in

  init)
    base="${1:-kanban}"
    base=$(slugify "$base")
    # Find a free board name: <base>, <base>-1, <base>-2, …
    board="$base"
    n=1
    while [[ -d "$board" ]]; do
      board="${base}-${n}"
      (( n++ ))
    done
    for col in "${COLUMNS[@]}"; do
      mkdir -p "$board/$col"
      echo "  created $board/$col/"
    done
    echo "Board initialised: $board/"
    echo "  → cd $board"
    ;;

  add)
    title="$*"
    if [[ -z "$title" ]]; then
      echo "Usage: kanban add <title>" >&2
      exit 1
    fi
    slug=$(slugify "$title")
    file="backlog/${slug}.md"
    if [[ ! -d "backlog" ]]; then
      echo "Error: backlog/ directory not found. Run 'kanban init' first." >&2
      exit 1
    fi
    if [[ -f "$file" ]]; then
      echo "Error: task already exists: $file" >&2
      exit 1
    fi
    cat > "$file" <<MDEOF
---
priority: medium
tags: []
---

# ${title}

Brief description of the task.

## Checklist

- [ ] Step one
- [ ] Step two
- [ ] Step three
MDEOF
    printf '%s\n' "$slug" >> "backlog/order.txt"
    echo "Created: $file"
    ;;

  move)
    task="${1:-}"
    column="${2:-}"
    if [[ -z "$task" || -z "$column" ]]; then
      echo "Usage: kanban move <task> <column>" >&2
      exit 1
    fi
    validate_column "$column"
    src=$(find_task "$task")
    if [[ ! -d "$column" ]]; then
      echo "Error: column directory '$column/' not found. Run 'kanban init' first." >&2
      exit 1
    fi
    src_col=$(dirname "$src")
    mv "$src" "$column/${task}.md"
    order_remove "$src_col" "$task"
    order_append "$column" "$task"
    echo "Moved: $task  →  $column"
    ;;

  list)
    column=""
    priority_filter=""
    tag_filter=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --priority)
          if [[ $# -lt 2 || "${2-}" == --* ]]; then
            echo "Error: --priority requires an argument (high|medium|low)" >&2
            usage
            exit 1
          fi
          priority_filter="$2"
          shift 2
          ;;
        --tag)
          if [[ $# -lt 2 || "${2-}" == --* ]]; then
            echo "Error: --tag requires an argument" >&2
            usage
            exit 1
          fi
          tag_filter="$2"
          shift 2
          ;;
        *)          column="$1";              shift   ;;
      esac
    done
    if [[ -n "$column" ]]; then
      validate_column "$column" || exit 1
      list_cols=("$column")
    else
      list_cols=("${COLUMNS[@]}")
    fi

    for col in "${list_cols[@]}"; do
      echo "## $col"
      if [[ ! -d "$col" ]]; then
        echo "  (missing)"
        continue
      fi

      # col_tasks: slug → "prio_ord|prio|tag_str"
      unset col_tasks; declare -A col_tasks=()

      shopt -s nullglob
      for f in "$col"/*.md; do
        fm_prio="medium" fm_tags="" fm_in=0 fm_dashes=0
        while IFS= read -r fm_line; do
          if [[ "$fm_line" == "---" ]]; then
            (( ++fm_dashes ))
            [[ $fm_dashes -eq 1 ]] && fm_in=1
            [[ $fm_dashes -eq 2 ]] && break
            continue
          fi
          [[ $fm_in -eq 1 ]] || continue
          if [[ "$fm_line" =~ ^priority:[[:space:]]*(.*) ]]; then
            fm_prio="${BASH_REMATCH[1]// /}"
            fm_prio="${fm_prio,,}"
          elif [[ "$fm_line" =~ ^tags:[[:space:]]*\[([^\]]*)\] ]]; then
            fm_tags="${BASH_REMATCH[1]}"
          fi
        done < "$f"

        [[ -n "$priority_filter" && "$fm_prio" != "$priority_filter" ]] && continue

        if [[ -n "$tag_filter" ]]; then
          tag_found=0
          IFS=',' read -ra tag_arr <<< "$fm_tags"
          for t in "${tag_arr[@]}"; do
            t="${t// /}"; t="${t,,}"
            [[ "$t" == "$tag_filter" ]] && { tag_found=1; break; }
          done
          [[ $tag_found -eq 0 ]] && continue
        fi

        slug=$(basename "$f" .md)

        tag_str=""
        if [[ -n "${fm_tags//[, ]/}" ]]; then
          tag_display=""
          IFS=',' read -ra tag_arr <<< "$fm_tags"
          for t in "${tag_arr[@]}"; do
            t="${t// /}"; t="${t,,}"
            [[ -n "$t" ]] && tag_display+="#$t "
          done
          tag_str="  ${tag_display% }"
        fi

        case "$fm_prio" in
          high)   prio_ord=0 ;;
          medium) prio_ord=1 ;;
          low)    prio_ord=2 ;;
          *)      prio_ord=3 ;;
        esac

        col_tasks["$slug"]="${prio_ord}|${fm_prio}|${tag_str}"
      done
      shopt -u nullglob

      if [[ ${#col_tasks[@]} -eq 0 ]]; then
        [[ -n "$priority_filter" || -n "$tag_filter" ]] \
          && echo "  (no matches)" || echo "  (empty)"
        continue
      fi

      # Print queue: order.txt entries first, then remaining sorted by priority
      unset seen_slugs; declare -A seen_slugs=()
      print_queue=()

      if [[ -f "$col/order.txt" ]]; then
        while IFS= read -r s; do
          [[ -z "${s// /}" || "$s" == \#* ]] && continue
          [[ -n "${col_tasks[$s]+x}" ]] || continue
          [[ -n "${seen_slugs[$s]+x}" ]] && continue
          print_queue+=("$s")
          seen_slugs["$s"]=1
        done < "$col/order.txt"
      fi

      remaining_sort=()
      for s in "${!col_tasks[@]}"; do
        [[ -n "${seen_slugs[$s]+x}" ]] && continue
        remaining_sort+=("${col_tasks[$s]%%|*}|${s}")
      done
      if [[ ${#remaining_sort[@]} -gt 0 ]]; then
        _tmp=$(mktemp)
        printf '%s\n' "${remaining_sort[@]}" | sort > "$_tmp"
        while IFS='|' read -r _ s; do
          print_queue+=("$s")
        done < "$_tmp"
        rm -f "$_tmp"
      fi

      for s in "${print_queue[@]}"; do
        IFS='|' read -r _ prio tag_str <<< "${col_tasks[$s]}"
        echo "  - $s  [$prio]$tag_str"
      done
    done
    ;;

  order)
    task="${1:-}"
    subcmd="${2:-}"
    n_arg="${3:-1}"

    if [[ -z "$task" || -z "$subcmd" ]]; then
      echo "Usage: kanban order <task> top|bottom|up [N]|down [N]" >&2
      exit 1
    fi

    if [[ "$subcmd" == "up" || "$subcmd" == "down" ]]; then
      if ! [[ "$n_arg" =~ ^[0-9]+$ ]] || [[ "$n_arg" -eq 0 ]]; then
        echo "Error: N must be a positive integer" >&2
        exit 1
      fi
    fi

    src=$(find_task "$task")
    col=$(dirname "$src")

    # Build complete ordered list: order.txt entries (that exist) then unlisted .md files
    unset in_order; declare -A in_order=()
    current_order=()

    if [[ -f "$col/order.txt" ]]; then
      while IFS= read -r s; do
        [[ -z "${s// /}" || "$s" == \#* ]] && continue
        [[ -f "$col/${s}.md" ]] || continue
        [[ -n "${in_order[$s]+x}" ]] && continue
        current_order+=("$s")
        in_order["$s"]=1
      done < "$col/order.txt"
    fi

    shopt -s nullglob
    for f in "$col"/*.md; do
      s=$(basename "$f" .md)
      [[ -n "${in_order[$s]+x}" ]] && continue
      current_order+=("$s")
      in_order["$s"]=1
    done
    shopt -u nullglob

    idx=-1
    for i in "${!current_order[@]}"; do
      [[ "${current_order[$i]}" == "$task" ]] && { idx=$i; break; }
    done
    [[ $idx -eq -1 ]] && { echo "Error: task '$task' not found in $col" >&2; exit 1; }

    len=${#current_order[@]}

    case "$subcmd" in
      top)    new_idx=0 ;;
      bottom) new_idx=$(( len - 1 )) ;;
      up)
        new_idx=$(( idx - n_arg ))
        [[ $new_idx -lt 0 ]] && new_idx=0
        ;;
      down)
        new_idx=$(( idx + n_arg ))
        [[ $new_idx -ge $len ]] && new_idx=$(( len - 1 ))
        ;;
      *)
        echo "Error: unknown subcommand '$subcmd'. Use: top, bottom, up [N], down [N]" >&2
        exit 1
        ;;
    esac

    # Remove from current position, insert at new position
    new_order=()
    for i in "${!current_order[@]}"; do
      [[ $i -eq $idx ]] && continue
      new_order+=("${current_order[$i]}")
    done
    final_order=("${new_order[@]:0:$new_idx}" "$task" "${new_order[@]:$new_idx}")

    printf '%s\n' "${final_order[@]}" > "$col/order.txt"
    echo "Order: '$task' is now position $(( new_idx + 1 )) of $len in $col"
    ;;

  show)
    task="${1:-}"
    if [[ -z "$task" ]]; then
      echo "Usage: kanban show <task>" >&2
      exit 1
    fi
    file=$(find_task "$task")
    cat "$file"
    ;;

  check)
    task="${1:-}"
    item="${2:-}"
    if [[ -z "$task" || -z "$item" ]]; then
      echo "Usage: kanban check <task> <item>" >&2
      exit 1
    fi
    file=$(find_task "$task")
    # Use python3 for reliable fixed-string search and in-place replace;
    # avoids grep/sed quoting pitfalls when item text starts with '-'.
    result=$(python3 -c "
import sys
path, item = sys.argv[1], sys.argv[2]
with open(path) as f:
    content = f.read()
unchecked = '- [ ] ' + item
checked   = '- [x] ' + item
if unchecked in content:
    with open(path, 'w') as f:
        f.write(content.replace(unchecked, checked, 1))
    print('checked')
elif checked in content:
    print('already')
else:
    print('notfound')
" "$file" "$item")
    case "$result" in
      checked)  echo "Checked: \"${item}\" in $task" ;;
      already)  echo "Already checked: \"${item}\" in $task" ;;
      notfound) echo "Error: checklist item not found: \"${item}\"" >&2; exit 1 ;;
    esac
    ;;

  status)
    echo "Board Status"
    echo "============"
    total=0
    for col in "${COLUMNS[@]}"; do
      shopt -s nullglob
      files=("$col"/*.md)
      shopt -u nullglob
      count=${#files[@]}
      printf "  %-10s %d\n" "$col" "$count"
      (( total += count )) || true
    done
    echo "------------"
    printf "  %-10s %d\n" "total" "$total"
    ;;

  ""|help|--help|-h)
    usage
    ;;

  *)
    echo "Error: unknown command '$cmd'" >&2
    echo "" >&2
    usage >&2
    exit 1
    ;;

esac
