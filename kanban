#!/usr/bin/env bash
# kanban — KanBanLess CLI
# Manages a Kanban board entirely in the file system.
# Board = directory, Columns = subdirectories, Tasks = .md files

set -euo pipefail

COLUMNS=("backlog" "todo" "doing" "done")

usage() {
  cat <<EOF
Usage: kanban <command> [args]

Commands:
  init [name]             Create a board folder with 4 column directories.
                          Defaults to 'kanban'; auto-increments if it exists
                          (kanban-1, kanban-2, …). cd into the folder to use
                          other commands.
  add <title>             Create a new task .md in backlog/
  move <task> <column>    Move a task file to a new column directory
  list [column]           List tasks; sorted high→medium→low by default
    [--priority high|medium|low]  Filter by priority
    [--tag <tag>]                 Filter by tag
  show <task>             Display a task's content
  check <task> <item>     Mark a checklist item complete
  status                  Show board summary (count per column)

Columns: backlog, todo, doing, done
EOF
}

# Convert a title to a URL/filename-safe slug
slugify() {
  echo "$1" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9]/-/g' \
    | sed 's/-\+/-/g' \
    | sed 's/^-//;s/-$//'
}

# Find which column contains a given task slug; prints the path or exits 1
find_task() {
  local slug="$1"
  # Validate slug to prevent path traversal and enforce slug format
  if [[ ! "$slug" =~ ^[a-z0-9-]+$ ]]; then
    echo "Error: invalid task slug '$slug'. Slugs must contain only lowercase letters, digits, and dashes." >&2
    return 1
  fi
  for col in "${COLUMNS[@]}"; do
    if [[ -f "$col/${slug}.md" ]]; then
      echo "$col/${slug}.md"
      return 0
    fi
  done
  echo "Error: task not found: $slug" >&2
  return 1
}

# Validate that a column name is one of the four known columns
validate_column() {
  local col="$1"
  for c in "${COLUMNS[@]}"; do
    [[ "$c" == "$col" ]] && return 0
  done
  echo "Error: invalid column '$col'. Must be one of: ${COLUMNS[*]}" >&2
  return 1
}

cmd="${1:-}"
shift || true

case "$cmd" in

  init)
    base="${1:-kanban}"
    base=$(slugify "$base")
    # Find a free board name: <base>, <base>-1, <base>-2, …
    board="$base"
    n=1
    while [[ -d "$board" ]]; do
      board="${base}-${n}"
      (( n++ ))
    done
    for col in "${COLUMNS[@]}"; do
      mkdir -p "$board/$col"
      echo "  created $board/$col/"
    done
    echo "Board initialised: $board/"
    echo "  → cd $board"
    ;;

  add)
    title="$*"
    if [[ -z "$title" ]]; then
      echo "Usage: kanban add <title>" >&2
      exit 1
    fi
    slug=$(slugify "$title")
    file="backlog/${slug}.md"
    if [[ ! -d "backlog" ]]; then
      echo "Error: backlog/ directory not found. Run 'kanban init' first." >&2
      exit 1
    fi
    if [[ -f "$file" ]]; then
      echo "Error: task already exists: $file" >&2
      exit 1
    fi
    cat > "$file" <<MDEOF
---
priority: medium
tags: []
---

# ${title}

Brief description of the task.

## Checklist

- [ ] Step one
- [ ] Step two
- [ ] Step three
MDEOF
    echo "Created: $file"
    ;;

  move)
    task="${1:-}"
    column="${2:-}"
    if [[ -z "$task" || -z "$column" ]]; then
      echo "Usage: kanban move <task> <column>" >&2
      exit 1
    fi
    validate_column "$column"
    src=$(find_task "$task")
    if [[ ! -d "$column" ]]; then
      echo "Error: column directory '$column/' not found. Run 'kanban init' first." >&2
      exit 1
    fi
    mv "$src" "$column/$(basename "$src")"
    echo "Moved: $task  →  $column"
    ;;

  list)
    column=""
    priority_filter=""
    tag_filter=""
    while [[ $# -gt 0 ]]; do
      case "$1" in
        --priority) priority_filter="${2:-}"; shift 2 ;;
        --tag)      tag_filter="${2:-}";      shift 2 ;;
        *)          column="$1";              shift   ;;
      esac
    done
    if [[ -n "$column" ]]; then
      validate_column "$column" || exit 1
    fi
    python3 -c "
import sys, os
from pathlib import Path

all_cols  = ['backlog', 'todo', 'doing', 'done']
col_arg   = sys.argv[1]
prio_f    = sys.argv[2] or None
tag_f     = sys.argv[3] or None
cols      = [col_arg] if col_arg else all_cols
PRIO_ORD  = {'high': 0, 'medium': 1, 'low': 2}

def read_frontmatter(path):
    priority, tags = 'medium', []
    lines = Path(path).read_text().splitlines()
    in_fm, dashes = False, 0
    for line in lines:
        if line.strip() == '---':
            dashes += 1
            in_fm = dashes == 1
            if dashes == 2: break
            continue
        if not in_fm: continue
        if line.startswith('priority:'):
            priority = line[len('priority:'):].strip().lower()
        elif line.startswith('tags:'):
            part = line[len('tags:'):].strip()
            if part.startswith('[') and part.endswith(']'):
                tags = [t.strip().lower() for t in part[1:-1].split(',') if t.strip()]
    return priority, tags

for col in cols:
    print(f'## {col}')
    if not os.path.isdir(col):
        print('  (missing)')
        continue
    tasks = []
    for f in sorted(Path(col).glob('*.md')):
        prio, tags = read_frontmatter(f)
        if prio_f and prio != prio_f: continue
        if tag_f and tag_f not in tags: continue
        tasks.append((prio, tags, f.stem))
    if not tasks:
        label = '(no matches)' if (prio_f or tag_f) else '(empty)'
        print(f'  {label}')
    else:
        for prio, tags, slug in sorted(tasks, key=lambda x: (PRIO_ORD.get(x[0], 3), x[2])):
            tag_str = ('  ' + ' '.join(f'#{t}' for t in tags)) if tags else ''
            print(f'  - {slug}  [{prio}]{tag_str}')
" "$column" "$priority_filter" "$tag_filter"
    ;;

  show)
    task="${1:-}"
    if [[ -z "$task" ]]; then
      echo "Usage: kanban show <task>" >&2
      exit 1
    fi
    file=$(find_task "$task")
    cat "$file"
    ;;

  check)
    task="${1:-}"
    item="${2:-}"
    if [[ -z "$task" || -z "$item" ]]; then
      echo "Usage: kanban check <task> <item>" >&2
      exit 1
    fi
    file=$(find_task "$task")
    # Use python3 for reliable fixed-string search and in-place replace;
    # avoids grep/sed quoting pitfalls when item text starts with '-'.
    result=$(python3 -c "
import sys
path, item = sys.argv[1], sys.argv[2]
with open(path) as f:
    content = f.read()
unchecked = '- [ ] ' + item
checked   = '- [x] ' + item
if unchecked in content:
    with open(path, 'w') as f:
        f.write(content.replace(unchecked, checked, 1))
    print('checked')
elif checked in content:
    print('already')
else:
    print('notfound')
" "$file" "$item")
    case "$result" in
      checked)  echo "Checked: \"${item}\" in $task" ;;
      already)  echo "Already checked: \"${item}\" in $task" ;;
      notfound) echo "Error: checklist item not found: \"${item}\"" >&2; exit 1 ;;
    esac
    ;;

  status)
    echo "Board Status"
    echo "============"
    total=0
    for col in "${COLUMNS[@]}"; do
      shopt -s nullglob
      files=("$col"/*.md)
      shopt -u nullglob
      count=${#files[@]}
      printf "  %-10s %d\n" "$col" "$count"
      (( total += count )) || true
    done
    echo "------------"
    printf "  %-10s %d\n" "total" "$total"
    ;;

  ""|help|--help|-h)
    usage
    ;;

  *)
    echo "Error: unknown command '$cmd'" >&2
    echo "" >&2
    usage >&2
    exit 1
    ;;

esac
